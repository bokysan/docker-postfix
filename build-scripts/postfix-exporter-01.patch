--- a/Dockerfile	2026-07-22 15:19:53
+++ b/Dockerfile	2026-07-22 15:21:19
@@ -1,9 +1,29 @@
+# syntax=docker/dockerfile:1.2
+# Step 1: Build the binary using Docker's native multi-platform Go support
+FROM --platform=$BUILDPLATFORM golang:1.26-alpine AS builder
+ARG TARGETPLATFORM
+ARG TARGETOS
+ARG TARGETARCH
+ARG TARGETVARIANT
+
+WORKDIR /app
+COPY . .
+
+# CGO_ENABLED=0 + -tags nosystemd: the sdjournal log source is cgo-only (it
+# links libsystemd), which can't be cross-compiled here. Upstream ships its
+# multi-arch binaries the same way; postfix logs come via a file, not journald.
+RUN CGO_ENABLED=0 GOOS=${TARGETOS} GOARCH=${TARGETARCH} GOARM=${TARGETVARIANT#v} \
+    go build -tags nosystemd -ldflags="-s -w" -o postfix_exporter .
+
+# Step 2: Final minimal image
 FROM scratch
 ARG TARGETPLATFORM
 LABEL org.opencontainers.image.source="https://github.com/hsn723/postfix_exporter" \
         org.opencontainers.image.authors="Hsn723" \
         org.opencontainers.image.title="postfix_exporter"
 EXPOSE 9154
-COPY $TARGETPLATFORM/postfix_exporter /
+# Legacy path for old helm charts so people do not run into issues
+COPY --from=builder /app/postfix_exporter /bin/postfix_exporter
+COPY --from=builder /app/postfix_exporter /postfix_exporter
 COPY LICENSE /
 ENTRYPOINT ["/postfix_exporter"]
